# Server port
PORT=3001

# Allowed browser origin(s) for CORS (comma-separated)
CLIENT_ORIGIN=http://localhost:5173

# How long to reuse cached feed aggregation (milliseconds)
CACHE_TTL_MS=120000

# Max concurrent RSS fetches
FETCH_CONCURRENCY=5

# Optional: directory for disk cache (default: ./data inside server)
# CACHE_DIR=./data

# ── Auth / Admin ─────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that have admin access.
# Admins can configure global Slack and Teams channel webhooks in the dashboard.
ADMIN_EMAILS=you@example.com,colleague@example.com

# ── Email (Netlify Functions / daily digest) ─────────────────────────────────
# Get your free API key at https://resend.com
# RESEND_API_KEY=

# Sender address — must be verified in Resend or use the test address below.
# Test (delivers only to your Resend account email, no domain verification needed):
#   FROM_EMAIL=CyberSec News <onboarding@resend.dev>
# Production (requires verified domain in Resend):
#   FROM_EMAIL=alerts@yourdomain.com
FROM_EMAIL=CyberSec News <info@cybersecuritynews.com>
